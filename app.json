{
  "expo": {
    "name": "Zuri Elegance",
    "slug": "zuri-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#50242A"
    },
    "ios": {
